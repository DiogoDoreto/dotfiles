{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "/nix/store/**": "allow",
      "/etc/nix/inputs/**": "allow",
    }
  },
  "provider": {
    "localhost": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Localhost",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "gemma-4-E4B": {
          "name": "gemma-4-E4B"
        }
      }
    },
    "myprovider": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Chungus",
      "options": {
        "baseURL": "http://192.168.0.3:8080/v1"
      },
      "models": {
        "qwen3.5-35b-a3b-coding": {
          "name": "Qwen3.5"
        }
      }
    }
  },
}
